{
  "name": "mantis-redteam",
  "version": "0.2.7",
  "description": "Open-source CLI toolkit for automated red-teaming of LLM-powered applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mantis": "dist/cli/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/cli.ts",
    "start": "node dist/cli/cli.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "ai-security",
    "llm-security",
    "red-team",
    "prompt-injection",
    "owasp",
    "cli",
    "appsec",
    "devsecops"
  ],
  "author": "farhanashrafdev",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farhanashrafdev/mantis.git"
  },
  "homepage": "https://github.com/farhanashrafdev/mantis#readme",
  "bugs": {
    "url": "https://github.com/farhanashrafdev/mantis/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "mantis-redteam": "^0.2.4",
    "ora": "^8.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
